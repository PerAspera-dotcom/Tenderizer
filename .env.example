DEEPL_API_KEY=

# Comma-separated list of frontend origins allowed to call the API.
# Defaults to http://localhost:5173 (Vite's dev server) if unset.
ALLOWED_ORIGINS=http://localhost:5173

# Postgres connection string. Unset = falls back to a local SQLite file
# (data/tenders.db); tests always ignore this (see tests/conftest.py).
# Local dev Postgres: docker compose up -d postgres
DATABASE_URL=postgresql://tenderizer:dev@localhost:5432/tenderizer

# Your Clerk instance's JWKS endpoint (Clerk dashboard -> API Keys, or
# https://<your-instance>.clerk.accounts.dev/.well-known/jwks.json). Required
# for every authenticated route to work — unset means every request 500s
# (auth.AuthNotConfigured), not just 401s, since no token could ever verify.
CLERK_JWKS_URL=

# Shared secret for operational endpoints (GET /api/health, GET
# /api/reports/latest) — cross-tenant operational data, gated separately
# from regular tenant users' Clerk sessions (see auth.verify_ops_token).
# Generate one with e.g. `openssl rand -hex 32`; pass it as
# `Authorization: Bearer <token>` from your uptime monitor / internal
# dashboard. Unset = every request to those two routes 500s.
OPS_API_TOKEN=

# Sentry DSN for error tracking. Unset = sentry_sdk.init() is never called,
# i.e. fully inert — not required for local dev.
SENTRY_DSN=

# In-process daily scrape (APScheduler, replaces Windows Task Scheduler).
# "true" (default) runs it; set to "false" to disable — e.g. if ever running
# more than one instance of this service, so only one of them schedules.
ENABLE_SCHEDULER=true

# Anthropic API key — used by Vault's metadata-extraction step (src/vault.py,
# Claude Vision over uploaded PDFs). Unset = ingestion still parses/chunks/
# embeds a document, but metadata extraction is skipped and it stays
# 'processing' rather than failing. Never hardcode this — see the
# proposal_tool/ pilot's own scripts for what NOT to do.
ANTHROPIC_API_KEY=

# CR-004 F4 — automated backups (src/backup.py). A backup always runs daily
# (03:00 UTC) and lands in data/backups/ either way; BACKUP_S3_* is what
# actually gets it off the box. AWS S3, Backblaze B2, and GCS (interop mode)
# are all S3-compatible — set BACKUP_S3_ENDPOINT_URL for B2/GCS, leave unset
# for AWS. Unset BACKUP_S3_BUCKET = backups stay local-only (fine for dev,
# NOT sufficient for disaster recovery in prod).
BACKUP_S3_BUCKET=
BACKUP_S3_ENDPOINT_URL=
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=
BACKUP_S3_REGION=
# Rolling retention window for backups (local + remote), in days.
BACKUP_RETENTION_DAYS=30

# CR-004 F4 — after this many consecutive daily failures for one source
# (TED/BOAMP/...), escalate an alert (Sentry + email below). The source is
# never auto-paused — an analyst decides that.
SOURCE_FAILURE_ALERT_THRESHOLD=3

# CR-004 F4 — alert channels for backup failures + escalated source
# failures (src/alerts.py). Both independently optional/inert if unset.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=alerts@tender-izer.com
