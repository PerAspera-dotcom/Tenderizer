DEEPL_API_KEY=

# Comma-separated list of frontend origins allowed to call the API.
# Defaults to http://localhost:5173 (Vite's dev server) if unset.
ALLOWED_ORIGINS=http://localhost:5173

# Postgres connection string. Unset = falls back to a local SQLite file
# (data/tenders.db); tests always ignore this (see tests/conftest.py).
# Local dev Postgres: docker compose up -d postgres
DATABASE_URL=postgresql://tenderizer:dev@localhost:5432/tenderizer

# Your Clerk instance's JWKS endpoint (Clerk dashboard -> API Keys, or
# https://<your-instance>.clerk.accounts.dev/.well-known/jwks.json). Required
# for every authenticated route to work — unset means every request 500s
# (auth.AuthNotConfigured), not just 401s, since no token could ever verify.
CLERK_JWKS_URL=

# Shared secret for operational endpoints (GET /api/health, GET
# /api/reports/latest) — cross-tenant operational data, gated separately
# from regular tenant users' Clerk sessions (see auth.verify_ops_token).
# Generate one with e.g. `openssl rand -hex 32`; pass it as
# `Authorization: Bearer <token>` from your uptime monitor / internal
# dashboard. Unset = every request to those two routes 500s.
OPS_API_TOKEN=

# Sentry DSN for error tracking. Unset = sentry_sdk.init() is never called,
# i.e. fully inert — not required for local dev.
SENTRY_DSN=

# In-process daily scrape (APScheduler, replaces Windows Task Scheduler).
# "true" (default) runs it; set to "false" to disable — e.g. if ever running
# more than one instance of this service, so only one of them schedules.
ENABLE_SCHEDULER=true
